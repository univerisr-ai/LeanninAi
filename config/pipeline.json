{
  "timezone": "Europe/Istanbul",
  "project_disk_limit_gb": 10,
  "dry_run_default": false,
  "llm": {
    "provider": "openrouter",
    "api_key_env": "OPENROUTER_API_KEY",
    "base_url": "https://openrouter.ai/api/v1/chat/completions",
    "primary_model": "qwen/qwen3-coder:free",
    "fallback_model": "stepfun/step-3.5-flash:free",
    "max_tokens": 2500,
    "temperature": 0.2,
    "request_timeout_seconds": 60
  },
  "quality_gates": {
    "min_confidence": 70,
    "min_novelty": 65,
    "max_semantic_similarity": 0.78,
    "max_title_similarity": 0.55,
    "max_concept_similarity": 0.50,
    "allowed_categories": [
      "frontend",
      "backend",
      "security",
      "ui-ux",
      "a11y"
    ]
  },
  "auto_publish": {
    "enabled": true,
    "min_confidence": 85,
    "min_novelty": 70,
    "min_word_count": 80,
    "purge_low_quality": true,
    "purge_max_confidence": 50
  },
  "weekly_digest": {
    "enabled": true,
    "lookback_days": 7,
    "run_day_of_week": 6
  },
  "brain_enhancement": {
    "enabled": true,
    "max_pages_per_run": 5,
    "min_score_threshold": 30.0,
    "min_age_days": 7.0
  },
  "sources": {
    "github_repos": {
      "enabled": true,
      "lookback_days": 14,
      "limit": 10,
      "query": "(frontend OR backend OR security OR accessibility) stars:>200 pushed:>={date}"
    },
    "owasp_cve_rss": {
      "enabled": true,
      "limit": 8,
      "feeds": [
        "https://www.cisa.gov/news-events/cybersecurity-advisories/all.xml",
        "https://nvd.nist.gov/feeds/xml/cve/misc/nvd-rss.xml"
      ]
    },
    "frontend_feeds": {
      "enabled": true,
      "limit": 12,
      "devto_tags": [
        "frontend",
        "react",
        "webdev",
        "security",
        "typescript",
        "nextjs",
        "a11y"
      ],
      "rss": [
        "https://www.smashingmagazine.com/feed/",
        "https://css-tricks.com/feed/"
      ]
    },
    "hackernews": {
      "enabled": true,
      "limit": 10,
      "lookback_hours": 48,
      "keywords": [
        "frontend", "backend", "web", "security", "api",
        "css", "javascript", "typescript", "node", "react",
        "xss", "csrf", "vulnerability", "accessibility"
      ]
    },
    "extra_rss": {
      "enabled": true,
      "limit": 8,
      "feeds": [
        { "url": "https://web.dev/feed.xml", "category": "frontend" },
        { "url": "https://blog.mozilla.org/en/feed/", "category": "frontend" },
        { "url": "https://github.blog/feed/", "category": "backend" }
      ]
    }
  },
  "multi_agent": {
    "enabled": true,
    "max_retries": 3,
    "maker_model": "qwen/qwen3-coder:free",
    "reviewer_model": "meta-llama/llama-3.3-70b-instruct:free",
    "fixer_model": "qwen/qwen3-coder:free",
    "auditor_model": "nousresearch/hermes-3-llama-3.1-405b:free",
    "architect_model": "trinity",
    "logic_model": "liquid/lfm-40b:free"
  }
}
